# ── Infra (docker-compose) ───────────────────────────────────────────────
POSTGRES_USER=ecomiq
POSTGRES_PASSWORD=ecomiq
POSTGRES_PORT=5432
POSTGRES_MULTIPLE_DATABASES=identity_db,catalog_db,inventory_db,order_db,payment_db,marketing_db,notification_db,shipping_db,crm_db,purchasing_db,media_db
REDIS_PORT=6379
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
ADMINER_PORT=8081
PULSAR_PORT=6650
PULSAR_ADMIN_PORT=8080
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=ecomiq
MINIO_ROOT_PASSWORD=ecomiq123

# ── identity-service ─────────────────────────────────────────────────────
IDENTITY_PORT=3001
IDENTITY_DB_HOST=localhost
IDENTITY_DB_PORT=5432
IDENTITY_DB_USER=ecomiq
IDENTITY_DB_PASSWORD=ecomiq
IDENTITY_DB_NAME=identity_db

REDIS_HOST=localhost
REDIS_PORT_APP=6379
# Unset (dev default) means identity's Redis
# client connects with no AUTH, identical to today. Prod sets this once
# `redis-server --requirepass` is enabled (docker-compose.prod.yml). Never
# commit a real value.
# REDIS_PASSWORD=

# RS256 keypair used to sign/verify access tokens (see apps/services/identity/scripts/generate-keys.ts)
JWT_PRIVATE_KEY_PATH=apps/services/identity/keys/private.pem
JWT_PUBLIC_KEY_PATH=apps/services/identity/keys/public.pem
JWT_KID=identity-key-1
JWT_ACCESS_TTL=15m
JWT_ISSUER=ecomiq-identity
JWT_INTERNAL_TTL=5m

# service_account client secrets for
# `npm run identity:service-accounts:seed`. Optional: unset means the script
# generates a random secret and prints it once. Never commit real values —
# export them in your shell before running the script instead.
# ORDER_SERVICE_CLIENT_SECRET=
# DEMO_GRPC_CLIENT_SECRET=

# Refresh token cookie
REFRESH_TOKEN_COOKIE_NAME=ecomiq_rt
REFRESH_TOKEN_TTL_DAYS=30

# Google OAuth2 (create credentials at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Mail (dev → Mailhog, no auth needed)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="Ecomiq <no-reply@ecomiq.dev>"

APP_WEB_URL=http://localhost:4200

# ── storefront (Next.js) ──────────────────────────────────────────────────
GATEWAY_INTERNAL_URL=http://localhost:3000/api
STOREFRONT_URL=http://localhost:4300
SESSION_COOKIE_SECURE=false

# ── api-gateway ───────────────────────────────────────────────────────────
GATEWAY_PORT=3000
IDENTITY_SERVICE_URL=http://localhost:3001/api
CATALOG_SERVICE_URL=http://localhost:3002/api
INVENTORY_SERVICE_URL=http://localhost:3003/api
# The three new services' upstream URLs, same reasoning as the
# catalog/inventory ones above.
ORDER_SERVICE_URL=http://localhost:3004/api
PAYMENT_SERVICE_URL=http://localhost:3005/api
MARKETING_SERVICE_URL=http://localhost:3006/api
# notification-service's upstream URL (async-only — no gRPC, so no
# NOTIFICATION_GRPC_PORT the way payment/marketing/inventory have one).
NOTIFICATION_SERVICE_URL=http://localhost:3007/api
# shipping-service's upstream URL — also async-only, no gRPC (nothing calls
# it synchronously per the plan's resource allocation).
SHIPPING_SERVICE_URL=http://localhost:3008/api
# crm-service's upstream URL — also async-only, no gRPC (nothing calls it
# synchronously per the plan's resource allocation).
CRM_SERVICE_URL=http://localhost:3009/api
# purchasing-service's upstream URL — also async-only, no gRPC (nothing
# calls it synchronously per the plan's resource allocation).
PURCHASING_SERVICE_URL=http://localhost:3010/api
# media-service's upstream URL — also async-only, no gRPC (nothing calls it
# synchronously per the plan's resource allocation).
MEDIA_SERVICE_URL=http://localhost:3011/api
JWKS_URI=http://localhost:3001/api/.well-known/jwks.json
CORS_ORIGIN=http://localhost:4200
# Redis-backed throttler storage so rate limits survive a gateway restart /
# are shared across replicas. docker-compose.yml overrides this to
# redis://redis:6379 (service-network address). ioredis parses credentials
# straight out of the URL (redis://:<password>@host:port) — no separate
# REDIS_PASSWORD var needed here the way identity's host/port-based client
# needs one; docker-compose.prod.yml sets this to the authenticated form
# once `redis-server --requirepass` is on.
REDIS_URL=redis://localhost:6379
# Raw body buffer limit for the proxy controllers (replaces per-route JSON
# body parsing so multipart/binary uploads forward through the gateway
# intact).
PROXY_BODY_LIMIT=25mb
# Upstream fetch timeout for the proxy handler; an abort past this maps to
# a 504 instead of hanging the connection forever.
PROXY_UPSTREAM_TIMEOUT_MS=10000

# ── catalog-service ───────────────────────────────────────────────────────
CATALOG_PORT=3002
CATALOG_DB_HOST=localhost
CATALOG_DB_PORT=5432
CATALOG_DB_USER=ecomiq
CATALOG_DB_PASSWORD=ecomiq
CATALOG_DB_NAME=catalog_db
CATALOG_PULSAR_NAMESPACE=catalog

# ── inventory-service ─────────────────────────────────────────────────────
INVENTORY_PORT=3003
INVENTORY_DB_HOST=localhost
INVENTORY_DB_PORT=5432
INVENTORY_DB_USER=ecomiq
INVENTORY_DB_PASSWORD=ecomiq
INVENTORY_DB_NAME=inventory_db
INVENTORY_PULSAR_NAMESPACE=inventory
# inventory-service's gRPC listener (ReservationService), consumed by
# order-service's checkout saga (ADR-7) via
# libs/contracts' createInventoryGrpcClient. Separate from INVENTORY_PORT
# (that's the HTTP/REST listener) — same hybrid-app pattern as the two Pulsar
# microservice connections in inventory's main.ts.
INVENTORY_GRPC_PORT=50051

# ── order-service ─────────────────────────────────────────────────────────
ORDER_PORT=3004
CRM_JWKS_URI=http://localhost:3003/api/.well-known/jwks.json
ORDER_DB_HOST=localhost
ORDER_DB_PORT=5432
ORDER_DB_USER=ecomiq
ORDER_DB_PASSWORD=ecomiq
ORDER_DB_NAME=order_db
ORDER_PULSAR_NAMESPACE=orders
# The checkout saga's InternalTokenClient fetches client-credentials
# tokens from here, then calls inventory/payment/marketing's gRPC servers.
# ORDER_SERVICE_CLIENT_SECRET must match whatever `identity:service-accounts:seed`
# pinned the `order-service` account's secret to (see that script's own
# secretEnvVar field) — never commit the real value, export it in your shell.
IDENTITY_TOKEN_URL=http://localhost:3001/api/auth/token
ORDER_SERVICE_CLIENT_ID=order-service
# ORDER_SERVICE_CLIENT_SECRET=
INVENTORY_GRPC_URL=localhost:50051
PAYMENT_GRPC_URL=localhost:50053
MARKETING_GRPC_URL=localhost:50052
# order-service also consumes payment-service's own `payments`
# namespace (payment-result events, via the PAYMENT_PULSAR_NAMESPACE var
# defined below in payment-service's own section — same root .env is shared
# by every service in local dev) and arms a self-addressed delayed message
# when a checkout enters awaiting_payment.
CHECKOUT_PAYMENT_TIMEOUT_MINUTES=30
# RMA auto-expiry delayed message; unset (dev default) means 14
# days. Override to a seconds-scale value (e.g. via shell export, never
# committed here) only when live-testing the expiry handler itself.
# RMA_EXPIRY_DAYS=14

# ── payment-service (provider-agnostic; the mock/Stripe choice + gRPC/webhook
# vars below select and configure the adapter) ────────────────────────────
PAYMENT_PORT=3005
PAYMENT_DB_HOST=localhost
PAYMENT_DB_PORT=5432
PAYMENT_DB_USER=ecomiq
PAYMENT_DB_PASSWORD=ecomiq
PAYMENT_DB_NAME=payment_db
PAYMENT_PULSAR_NAMESPACE=payments
# payment-service's gRPC listener (PaymentIntentService), consumed
# by order-service's checkout saga (ADR-7) via libs/contracts'
# createPaymentGrpcClient. Separate from PAYMENT_PORT (the HTTP listener).
PAYMENT_GRPC_PORT=50053
# Selects the PaymentProviderPort adapter (provider.module.ts).
# Unset (dev default) means "mock" — the only adapter implemented today;
# "stripe" (or any other value) throws at boot until a real adapter exists.
# PAYMENT_PROVIDER=mock
# HMAC secret the mock provider signs/verifies webhook bodies with
# (MockPaymentProvider, simulate-webhook.ts). Unset (dev default) means
# "dev-mock-webhook-secret" — fine for local dev, never use the default in
# a shared/prod environment.
# MOCK_WEBHOOK_SECRET=dev-mock-webhook-secret

# ── marketing-service (discounts first, then campaigns/ads/popups/forms) ──
MARKETING_PORT=3006
MARKETING_DB_HOST=localhost
MARKETING_DB_PORT=5432
MARKETING_DB_USER=ecomiq
MARKETING_DB_PASSWORD=ecomiq
MARKETING_DB_NAME=marketing_db
MARKETING_PULSAR_NAMESPACE=marketing
# marketing-service's gRPC listener (DiscountService), consumed
# by order-service's checkout saga (ADR-7) via libs/contracts'
# createMarketingGrpcClient. Separate from MARKETING_PORT (the HTTP listener).
MARKETING_GRPC_PORT=50052

# ── notification-service (staff-recipient config vars arrive with the
# steps that need them) ────────────────────────────────────────────────────
NOTIFICATION_PORT=3007
NOTIFICATION_DB_HOST=localhost
NOTIFICATION_DB_PORT=5432
NOTIFICATION_DB_USER=ecomiq
NOTIFICATION_DB_PASSWORD=ecomiq
NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_PULSAR_NAMESPACE=notify
# Selects each channel's ProviderPort adapter (channels.module.ts). Unset
# (dev default) means "mock" — the only adapter implemented today; any
# other value throws at boot until a real adapter exists.
# NOTIFICATION_EMAIL_PROVIDER=mock
# NOTIFICATION_SMS_PROVIDER=mock
# NOTIFICATION_WHATSAPP_PROVIDER=mock
# DispatchService's retry/DLQ tunables — a send gets this many total
# attempts (first try + retries) before flipping to `dead`. Backoff between
# attempts is exponential-with-jitter between base and max.
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_RETRY_BASE_MS=60000
NOTIFICATION_RETRY_MAX_MS=1800000
# HMAC secret the mock email provider signs/verifies webhook bodies with
# (MockEmailProvider, webhooks.controller.ts). Unset (dev default) means
# "dev-mock-webhook-secret" — fine for local dev, never use the default in
# a shared/prod environment.
# NOTIFICATION_WEBHOOK_SECRET=dev-mock-webhook-secret
# notification-service's own internal service-account (WebhookDispatchService's
# InternalTokenClient, forwarding engagement events to marketing) — must
# match whatever `identity:service-accounts:seed` pinned the
# `notification-service` account's secret to (see that script's own
# secretEnvVar field).
NOTIFICATION_SERVICE_CLIENT_ID=notification-service
# NOTIFICATION_SERVICE_CLIENT_SECRET=
# StockLowController's staff recipients — env-configured for now, not a
# per-store setting (crm/identity-level store contact config doesn't exist
# yet; noted as a known gap, not something this step tries to close).
NOTIFICATION_STAFF_EMAIL=staff@ecomiq.dev
NOTIFICATION_STAFF_PHONE=+10000000000

# ── shipping-service (carrier port/mock adapter config + webhook secret
# arrive with the steps that need them) ────────────────────────────────────
SHIPPING_PORT=3008
SHIPPING_DB_HOST=localhost
SHIPPING_DB_PORT=5432
SHIPPING_DB_USER=ecomiq
SHIPPING_DB_PASSWORD=ecomiq
SHIPPING_DB_NAME=shipping_db
SHIPPING_PULSAR_NAMESPACE=shipping
# Selects CarrierProviderPort's adapter (carrier.module.ts). Unset (dev
# default) means "mock" — the only adapter implemented today; any other
# value throws at boot until a real adapter exists.
# SHIPPING_CARRIER_PROVIDER=mock
# HMAC secret the tracking webhook verifies signed carrier events against
# (signature.util.ts, tracking-webhook.controller.ts). Unset (dev default)
# means "dev-mock-webhook-secret" — fine for local dev, never use the
# default in a shared/prod environment.
# SHIPPING_WEBHOOK_SECRET=dev-mock-webhook-secret

# ── crm-service (loyalty/referral tuning arrives with the steps that need
# them) ──────────────────────────────────────────────────────────────────────
CRM_PORT=3009
CRM_DB_HOST=localhost
CRM_DB_PORT=5432
CRM_DB_USER=ecomiq
CRM_DB_PASSWORD=ecomiq
CRM_DB_NAME=crm_db
CRM_PULSAR_NAMESPACE=crm
# RS256 keypair for the *customer* JWT principal (run `npm run
# crm:keys:generate` first) — entirely separate from identity's own
# JWT_PRIVATE_KEY_PATH/JWT_PUBLIC_KEY_PATH/JWT_KID/JWT_ISSUER.
CRM_JWT_PRIVATE_KEY_PATH=apps/services/crm/keys/private.pem
CRM_JWT_PUBLIC_KEY_PATH=apps/services/crm/keys/public.pem
CRM_JWT_KID=crm-customer-key-1
CRM_JWT_ACCESS_TTL=15m
CRM_JWT_ISSUER=ecomiq-crm-customer
# crm-service verifies its own customer tokens against its own JWKS — self-
# referential, same as identity issuing+verifying its own staff tokens.
CRM_JWKS_URI=http://localhost:3009/api/auth/jwks
# Rotating refresh-token cookie (Redis-backed reuse detection, crm:rt:/
# crm:rtfam: key prefix — same Redis instance as identity, distinguishable keys).
CRM_REFRESH_TOKEN_COOKIE_NAME=ecomiq_customer_rt
CRM_REFRESH_TOKEN_TTL_DAYS=30
# Loyalty accrual: floor(totalMinor / 100) * CRM_LOYALTY_EARN_RATE points per
# order. Tier thresholds are point totals, bronze is the default below silver.
CRM_LOYALTY_EARN_RATE=1
CRM_LOYALTY_TIER_SILVER=500
CRM_LOYALTY_TIER_GOLD=2000
# Points issued to the referrer once their referee's first order completes the referral.
CRM_REFERRAL_REWARD_POINTS=500

# ── purchasing-service ────────────────────────────────────────────────────
PURCHASING_PORT=3010
PURCHASING_DB_HOST=localhost
PURCHASING_DB_PORT=5432
PURCHASING_DB_USER=ecomiq
PURCHASING_DB_PASSWORD=ecomiq
PURCHASING_DB_NAME=purchasing_db
PURCHASING_PULSAR_NAMESPACE=purchasing
# RS256 keypair for the *supplier* JWT principal (run `npm run
# purchasing:keys:generate` first) — entirely separate from identity's own
# JWT_PRIVATE_KEY_PATH/JWT_PUBLIC_KEY_PATH/JWT_KID/JWT_ISSUER and crm's
# CRM_JWT_*.
PURCHASING_JWT_PRIVATE_KEY_PATH=apps/services/purchasing/keys/private.pem
PURCHASING_JWT_PUBLIC_KEY_PATH=apps/services/purchasing/keys/public.pem
PURCHASING_JWT_KID=purchasing-supplier-key-1
PURCHASING_JWT_ACCESS_TTL=15m
PURCHASING_JWT_ISSUER=ecomiq-purchasing-supplier
# purchasing-service verifies its own supplier tokens against its own
# JWKS — self-referential, same as identity/crm issuing+verifying their own
# tokens.
PURCHASING_JWKS_URI=http://localhost:3010/api/auth/jwks
# Rotating refresh-token cookie (Redis-backed reuse detection,
# purchasing:rt:/purchasing:rtfam: key prefix — same Redis instance as
# identity/crm, distinguishable keys).
PURCHASING_REFRESH_TOKEN_COOKIE_NAME=ecomiq_supplier_rt
PURCHASING_REFRESH_TOKEN_TTL_DAYS=30

# ── media-service (File Library envs arrive with the steps that need them) ─
MEDIA_PORT=3011
MEDIA_DB_HOST=localhost
MEDIA_DB_PORT=5432
MEDIA_DB_USER=ecomiq
MEDIA_DB_PASSWORD=ecomiq
MEDIA_DB_NAME=media_db
MEDIA_PULSAR_NAMESPACE=media
# S3-compatible object storage (MinIO in dev/docker-compose; a real AWS S3
# or R2 bucket later is a pure env-var swap, no code change — see the
# client factory in storage.module.ts for why two endpoints exist).
MEDIA_S3_BUCKET=ecomiq-media
# Internal: what media-service itself uses for every SDK operation
# (put/head/delete/list) — reaches MinIO over the compose network.
MEDIA_S3_ENDPOINT=http://localhost:9000
# Public: what presigned URLs are signed against, since a URL signed over
# `minio:9000` (only resolvable inside the compose network) 404s the moment
# a browser tries to use it. docker-compose overrides MEDIA_S3_ENDPOINT to
# `http://minio:9000` for the internal client; this one stays
# browser-reachable in both bare-metal dev and compose.
MEDIA_S3_PUBLIC_ENDPOINT=http://localhost:9000
MEDIA_S3_REGION=us-east-1
MEDIA_S3_ACCESS_KEY=ecomiq
MEDIA_S3_SECRET_KEY=ecomiq123
# Upload flow validation (presign + complete both re-check these).
# Uploads bypass the gateway's PROXY_BODY_LIMIT entirely (presign-direct-to-
# MinIO), so this is the only size ceiling that applies.
MEDIA_MAX_SIZE_BYTES=209715200
MEDIA_ALLOWED_MIME_PREFIXES=image/,video/,application/pdf
# Image transforms (GET /files/:id/image?w=&h=&fit=): clamps requested w/h
# so the derived/<id>/ key space stays bounded — a client can't force
# arbitrarily large sharp resizes or an unbounded number of cached variants.
MEDIA_MAX_TRANSFORM_DIMENSION=2000

# ── Pulsar (event bus) ────────────────────────────────────────────────────
# Client-facing URLs services connect to (host-mapped ports from docker-compose).
PULSAR_SERVICE_URL=pulsar://localhost:6650
PULSAR_ADMIN_URL=http://localhost:8080
# Namespace convention: tenant "ecomiq", one namespace per owning service —
# each service reads its own <SERVICE>_PULSAR_NAMESPACE var above (not a
# shared key here) so namespaces don't collide when multiple services run
# side-by-side via `nx serve` against this one root .env (topics look like
# persistent://ecomiq/catalog/catalog.product.events).
PULSAR_TENANT=ecomiq
# Unset (dev default) means every Pulsar client
# (PulsarProducerService, PulsarServer, the outbox relay) connects with no
# `authentication` field, identical to today's unauthenticated standalone
# broker. Prod enables broker-side token auth (docker-compose.prod.yml) and
# sets this to a token minted for that broker's secret key — see the "Prod
# gate checklist" below for the exact commands. Never commit a real value.
# PULSAR_AUTH_TOKEN=

# ── Prod gate checklist (covers order/payment/marketing too) ─────────────
# Before `docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d`:
#   1. Pulsar token auth: generate a secret key + a token minted from it
#      (see docker-compose.prod.yml's pulsar service comment for the exact
#      `bin/pulsar tokens ...` commands), set PULSAR_AUTH_TOKEN above.
#   2. Redis password: set REDIS_PASSWORD above and give REDIS_URL's
#      embedded credentials the same value (redis://:<password>@redis:6379).
#   3. Service ports unpublished: docker-compose.prod.yml already handles
#      this (identity/catalog/inventory/order/payment/marketing/pulsar,
#      including payment's/marketing's internal-only gRPC ports) — nothing
#      to set here.
#   4. NODE_ENV=production: docker-compose.prod.yml already sets this for
#      every app service — nothing to set here.
#   5. Migrations run: docker-compose.prod.yml's *-migrate one-off services
#      handle this automatically (each app service depends_on its migrate
#      service completing, including order-migrate/payment-migrate/
#      marketing-migrate) — nothing to run manually.
#   6. ORDER_SERVICE_CLIENT_SECRET set (above) — the checkout saga's
#      InternalTokenClient auth-fails every gRPC call without it; see
#      `identity:service-accounts:seed`'s own output for the value to use.
#   7. PAYMENT_PROVIDER/MOCK_WEBHOOK_SECRET (above) — fine to leave unset
#      (both have safe dev defaults); set explicitly once a real
#      Stripe-backed adapter exists and PAYMENT_PROVIDER=mock is no longer
#      what you want in this environment.
#   8. Pulsar namespaces/topics provisioned: `npm run pulsar:provision`
#      covers the full stack (catalog/inventory/orders/
#      payments/marketing) — run it once against the fresh broker before
#      expecting any service's consumer to come up healthy (TESTING.md
#      gotcha #7).
