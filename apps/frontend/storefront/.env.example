# Storefront Environment Variables

# The base URL of the storefront (used for canonical URLs and sitemaps)
STOREFRONT_URL=http://localhost:4300

# The base URL of the API gateway (used by the browser to reach the API)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000/api

# The internal URL of the API gateway (used by Next.js server components)
# In Docker, this is typically http://api-gateway:3000/api
GATEWAY_INTERNAL_URL=http://localhost:3000/api
